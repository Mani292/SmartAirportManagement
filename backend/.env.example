# ── ServiceNow Configuration ───────────────────────────────────────────────
# Your ServiceNow instance URL (no trailing slash)
SERVICENOW_INSTANCE=https://your-instance.service-now.com

# ServiceNow admin credentials
SERVICENOW_USERNAME=admin
SERVICENOW_PASSWORD=your_password_here

# ── AI (Groq) Configuration ────────────────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Email Notifications (Gmail SMTP) ──────────────────────────────────────
# Use an App Password (not your real password): https://myaccount.google.com/apppasswords
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# ── WhatsApp Notifications (WAHA) ─────────────────────────────────────────
# Run WAHA locally: docker run -p 3000:3000 devlikeapro/waha
WAHA_URL=http://localhost:3000
WAHA_API_KEY=your_waha_api_key_here
